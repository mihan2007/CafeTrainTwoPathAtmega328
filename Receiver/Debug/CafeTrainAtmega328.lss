     5e6:	0e 94 84 02 	call	0x508	; 0x508 <LCD_Data>
	uint8_t row_offsets[] = {0x00, 0x40, 0x14, 0x54};
	LCD_Command(0x80 | (col + row_offsets[row])); // Óńňŕíîâęŕ ŕäđĺńŕ DDRAM
}

