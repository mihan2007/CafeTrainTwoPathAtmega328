000005da <LCD_Print>:
void LCD_SetCursor(uint8_t col, uint8_t row) {
	uint8_t row_offsets[] = {0x00, 0x40, 0x14, 0x54};
	LCD_Command(0x80 | (col + row_offsets[row])); // Установка адреса DDRAM
}

